# Copy this file to `.env` locally (do NOT commit `.env`).
# Get these values from Lovable → Project Settings → Cloud.
# On Cloudflare/Vercel/Netlify, set the same variables in the host's dashboard
# instead of uploading a .env file.

# --- Client (bundled into the browser at build time) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Server (used by SSR / server functions at runtime) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
